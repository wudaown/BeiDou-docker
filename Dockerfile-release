# 使用基础镜像
FROM ubuntu:20.04 AS builder

# 设置非交互式安装
ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=UTC

# 安装需要的工具
RUN apt-get update && \
    apt-get install -y curl jq maven git wget nodejs npm && \
    apt-get clean

# 安装 Java 21
RUN wget -q https://download.java.net/java/GA/jdk21.0.2/f2283984656d49d69e91c558476027ac/13/GPL/openjdk-21.0.2_linux-x64_bin.tar.gz && \
    tar -xzf openjdk-21.0.2_linux-x64_bin.tar.gz -C /opt/ && \
    rm openjdk-21.0.2_linux-x64_bin.tar.gz

ENV JAVA_HOME=/opt/jdk-21.0.2
ENV PATH=$JAVA_HOME/bin:$PATH

ARG GITHUB_OWNER=wudaown
ARG GITHUB_REPO=BeiDou-Server

# 从源码构建
RUN git clone --depth 1 https://github.com/${GITHUB_OWNER}/${GITHUB_REPO}.git /opt/source

# 构建后端
RUN cd /opt/source && \
    mvn clean package -DskipTests -B && \
    mkdir -p /opt/server_unzip && \
    cp gms-server/target/BeiDou.jar /opt/server_unzip/

# 构建前端 UI
RUN cd /opt/source/gms-ui && \
    npm install && \
    npm run build && \
    mkdir -p /opt/server_unzip/static && \
    cp -r dist/* /opt/server_unzip/static/

# 复制配置文件和资源
RUN cp /opt/source/gms-server/src/main/resources/application.yml /opt/server_unzip/
RUN cp -r /opt/source/gms-server/wz /opt/server_unzip/
RUN cp -r /opt/source/gms-server/wz-zh-CN /opt/server_unzip/
RUN cp -r /opt/source/gms-server/scripts /opt/server_unzip/
RUN cp -r /opt/source/gms-server/scripts-zh-CN /opt/server_unzip/

# final image
FROM ubuntu:20.04

ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8

# 安装 Java 21
RUN apt-get update && \
    apt-get install -y wget && \
    wget -q https://download.java.net/java/GA/jdk21.0.2/f2283984656d49d69e91c558476027ac/13/GPL/openjdk-21.0.2_linux-x64_bin.tar.gz && \
    tar -xzf openjdk-21.0.2_linux-x64_bin.tar.gz -C /opt/ && \
    rm openjdk-21.0.2_linux-x64_bin.tar.gz && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

ENV JAVA_HOME=/opt/jdk-21.0.2
ENV PATH=$JAVA_HOME/bin:$PATH

COPY --from=builder /opt/server_unzip /opt/server_backup

COPY entrypoint-release.sh /

RUN chmod +x entrypoint-release.sh

VOLUME /opt/server

EXPOSE 8686 8484 7575 7576 7577

ENTRYPOINT ["/entrypoint-release.sh"]
