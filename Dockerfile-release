# 使用基础镜像
FROM ubuntu:20.04 AS builder

# 安装需要的工具
RUN apt-get update && \
    apt-get install -y curl jq maven && \
    apt-get clean

ARG GITHUB_OWNER=wudaown
ARG GITHUB_REPO=BeiDou-Server

ARG RELEASE_PREFIX_GIT_TAG=Release
ARG RELEASE_VERSION
ARG RELEASE_ARCH

# 尝试从 release 下载，如果失败则从源码构建
RUN set -e && \
    curl -s https://api.github.com/repos/${GITHUB_OWNER}/${GITHUB_REPO}/releases/tags/${RELEASE_VERSION} \
    | jq -r '.assets[] | select(.name | endswith("'${RELEASE_ARCH}'.tar.gz")) | .browser_download_url' \
    | xargs -n 1 curl -fsSL -o latest_release.tar.gz \
    || echo "No release found, building from source..."

RUN if [ -f latest_release.tar.gz ]; then \
        mkdir -p /opt/server_unzip && \
        tar -xzvf latest_release.tar.gz -C /opt/server_unzip --strip-components=1; \
    else \
        echo "Building from source..." && \
        git clone https://github.com/${GITHUB_OWNER}/${GITHUB_REPO}.git /opt/source && \
        cd /opt/source && \
        mvn clean package -DskipTests -B && \
        mkdir -p /opt/server_unzip && \
        cp gms-server/target/BeiDou.jar /opt/server_unzip/; \
    fi

# alpine好像缺点东西
FROM ubuntu:20.04

ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8

COPY --from=builder /opt/server_unzip /opt/server_backup

COPY entrypoint-release.sh /

RUN chmod +x entrypoint-release.sh

VOLUME /opt/server

EXPOSE 8686 8484 7575 7576 7577

ENTRYPOINT ["/entrypoint-release.sh"]
